# LifeOS Frontend Configuration
# Copy to .env and fill in values: cp .env.example .env

# ── Backend URL (host your backend and set this to that URL) ──
# The app uses this for API calls and for Google Sign-In redirect (URL + /oauth/google/callback).
# Example: https://api.yourdomain.com  or  http://192.168.1.100:8080 for local
EXPO_PUBLIC_BACKEND_URL=http://192.168.1.100:8080

# ── Google OAuth (from https://console.cloud.google.com/apis/credentials) ──
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional: override Google redirect URI (default is EXPO_PUBLIC_BACKEND_URL + /oauth/google/callback)
# EXPO_PUBLIC_GOOGLE_REDIRECT_URI=https://api.yourdomain.com/oauth/google/callback

# If you get "client_secret is missing": create a Desktop app OAuth client in Google Cloud and set:
# EXPO_PUBLIC_GOOGLE_USE_DESKTOP_CLIENT=true

# ── MQTT credentials (must match your broker / backend MQTT_* env) ──
EXPO_PUBLIC_MQTT_USERNAME=lifeos_user1
EXPO_PUBLIC_MQTT_PASSWORD=lifeos_user1_pass
